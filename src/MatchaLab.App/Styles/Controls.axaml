<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style Selector="TextBlock.label">
        <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="LetterSpacing" Value="1.9" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Opacity" Value="0.5" />
    </Style>

    <Style Selector="TextBlock.num">
        <Setter Property="FontFamily" Value="{DynamicResource NumFont}" />
        <Setter Property="FontWeight" Value="Black" />
    </Style>

    <Style Selector="TextBlock.display">
        <Setter Property="FontFamily" Value="{DynamicResource AccentFont}" />
    </Style>

    <Style Selector="TextBlock.mono">
        <Setter Property="FontFamily" Value="{DynamicResource MonoFont}" />
    </Style>

    <Style Selector="TextBlock.swap">
        <Setter Property="RenderTransformOrigin" Value="50%,50%" />
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.28" Easing="SineEaseOut" />
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.28" Easing="CubicEaseOut" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Border.card">
        <Setter Property="CornerRadius" Value="26" />
        <Setter Property="Padding" Value="18" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="#12FFFFFF" />
        <Setter Property="BoxShadow" Value="0 14 34 -12 #66000000" />
    </Style>

    <Style Selector="Button.reset">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="RenderTransformOrigin" Value="50%,50%" />
        <Setter Property="Transitions">
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.18" Easing="CubicEaseOut" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.reset:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.reset:pressed">
        <Setter Property="RenderTransform" Value="scale(0.97)" />
    </Style>

    <Style Selector="Button.lift:pointerover">
        <Setter Property="RenderTransform" Value="translateY(-2px)" />
    </Style>

    <Style Selector="TextBox">
        <Setter Property="Background" Value="#14FFFFFF" />
        <Setter Property="Foreground" Value="{DynamicResource Cream}" />
        <Setter Property="CaretBrush" Value="{DynamicResource Accent}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource Accent}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="#1FFFFFFF" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="13,9" />
        <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="#1AFFFFFF" />
        <Setter Property="BorderBrush" Value="#33FFFFFF" />
    </Style>
    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="#1AFFFFFF" />
        <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
    </Style>
    <Style Selector="TextBox:pointerover, TextBox:focus">
        <Setter Property="Foreground" Value="{DynamicResource Cream}" />
    </Style>

    <Style Selector="ToggleButton.chip">
        <Setter Property="Background" Value="#22FFFFFF" />
        <Setter Property="Foreground" Value="{DynamicResource Cream}" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="12,7" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="ToggleButton.chip:checked /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource Accent}" />
        <Setter Property="TextElement.Foreground" Value="{DynamicResource Ink}" />
    </Style>

    <Style Selector="ToggleButton.switch">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <ControlTemplate>

                <Border Name="track" Width="48" Height="28" CornerRadius="14" Background="#2EFFFFFF" ClipToBounds="True">
                    <Border.Transitions>
                        <Transitions>
                            <BrushTransition Property="Background" Duration="0:0:0.2" />
                        </Transitions>
                    </Border.Transitions>
                    <Border Name="knob" Width="22" Height="22" CornerRadius="11" Background="{DynamicResource Cream}"
                            HorizontalAlignment="Left" VerticalAlignment="Center" Margin="3,0,0,0"
                            RenderTransformOrigin="50%,50%">
                        <Border.Transitions>
                            <Transitions>
                                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.28" Easing="BackEaseOut" />
                                <BrushTransition Property="Background" Duration="0:0:0.2" />
                            </Transitions>
                        </Border.Transitions>
                    </Border>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="ToggleButton.switch:checked /template/ Border#track">
        <Setter Property="Background" Value="{DynamicResource Accent}" />
    </Style>
    <Style Selector="ToggleButton.switch:checked /template/ Border#knob">
        <Setter Property="RenderTransform" Value="translateX(20px)" />
        <Setter Property="Background" Value="{DynamicResource Ink}" />
    </Style>

    <Style Selector="ToggleButton.switch:pressed /template/ Border#knob">
        <Setter Property="RenderTransform" Value="scale(0.85)" />
    </Style>
    <Style Selector="ToggleButton.switch:checked:pressed /template/ Border#knob">
        <Setter Property="RenderTransform" Value="translateX(20px) scale(0.85)" />
    </Style>

    <Style Selector="ScrollBar:vertical">
        <Setter Property="Width" Value="7" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="Transparent" Padding="2,3">
                    <Track Minimum="{TemplateBinding Minimum}" Maximum="{TemplateBinding Maximum}"
                           Value="{TemplateBinding Value, Mode=TwoWay}"
                           ViewportSize="{TemplateBinding ViewportSize}"
                           Orientation="Vertical" IsDirectionReversed="True">
                        <Track.DecreaseButton>
                            <RepeatButton Name="PART_PageUpButton" Classes="scrolltrack" Focusable="False" />
                        </Track.DecreaseButton>
                        <Track.IncreaseButton>
                            <RepeatButton Name="PART_PageDownButton" Classes="scrolltrack" Focusable="False" />
                        </Track.IncreaseButton>
                        <Thumb Name="ScrollThumb" />
                    </Track>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="RepeatButton.scrolltrack">
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="Transparent" />
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="ScrollBar /template/ Thumb#ScrollThumb">
        <Setter Property="Background" Value="#1AFFFFFF" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="1" CornerRadius="1.5" />
            </ControlTemplate>
        </Setter>
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.15" />
                <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="ScrollBar /template/ Thumb#ScrollThumb:pointerover">
        <Setter Property="Background" Value="#33FFFFFF" />
    </Style>
    <Style Selector="ScrollBar /template/ Thumb#ScrollThumb:pressed">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
    </Style>
</Styles>
