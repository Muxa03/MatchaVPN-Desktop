<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MatchaLab.App.Views.KeyView">
    <Grid>

        <Ellipse Width="520" Height="520" HorizontalAlignment="Center" VerticalAlignment="Center"
                 IsHitTestVisible="False" Fill="{DynamicResource GlowSoftBrush}" />

        <Button Classes="reset lift" Click="Back_Click" HorizontalAlignment="Left" VerticalAlignment="Top"
                Margin="20,12,0,0" IsVisible="{Binding HasKey}">
            <Border Width="40" Height="40" CornerRadius="14" Background="{DynamicResource Card}">
                <Viewbox Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Canvas Width="24" Height="24">
                        <Path Data="M 15,4 L 8,12 L 15,20" Stroke="{DynamicResource Cream}" StrokeThickness="2.6"
                              StrokeLineCap="Round" StrokeJoin="Round" />
                    </Canvas>
                </Viewbox>
            </Border>
        </Button>

        <Border Classes="card" MaxWidth="352" VerticalAlignment="Center" HorizontalAlignment="Stretch"
                Margin="26" CornerRadius="30" Background="{DynamicResource Card}" Padding="26,32">
            <StackPanel Spacing="0">
                <TextBlock Classes="display" FontSize="44" FontWeight="Black" HorizontalAlignment="Center"><Run Text="MAT" Foreground="{DynamicResource Cream}" /><Run Text="CHA" Foreground="{DynamicResource Accent}" /></TextBlock>
                <TextBlock Text="введи ключ доступа" Opacity="0.6" HorizontalAlignment="Center"
                           Foreground="{DynamicResource Cream}" Margin="0,6,0,0" />

                <TextBox x:Name="KeyBox" Watermark="matcha://sub?token=… или сам ключ"
                         KeyDown="Key_KeyDown" Margin="0,26,0,0" />

                <Button Classes="reset lift" Click="Activate_Click" Margin="0,12,0,0">
                    <Border CornerRadius="14" Background="{DynamicResource Accent}" Padding="0,13"
                            BoxShadow="{DynamicResource MenuGlow}">
                        <TextBlock Text="активировать" FontSize="15" FontWeight="Bold"
                                   Foreground="{DynamicResource Ink}" HorizontalAlignment="Center" />
                    </Border>
                </Button>

                <TextBlock Text="{Binding ErrorText}" Foreground="#FFE58A8A" TextWrapping="Wrap" Margin="0,12,0,0"
                           IsVisible="{Binding ErrorText, Converter={x:Static ObjectConverters.IsNotNull}}" />

                <TextBlock Text="ключ выдаёт бот в Telegram после оплаты подписки" Opacity="0.4" FontSize="12"
                           TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center"
                           Foreground="{DynamicResource Cream}" Margin="0,20,0,0" />

                <Button Classes="reset" Click="Bot_Click" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <Border CornerRadius="12" Background="#1EFFFFFF" Padding="14,9">
                        <TextBlock FontSize="13" FontWeight="Bold" Foreground="{DynamicResource Accent}"
                                   Text="получить ключ - @MatchaVPN_bot" />
                    </Border>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
