<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MatchaLab.App.Views.SplashWindow"
        Title="MatchaVPN"
        Width="340" Height="420" CanResize="False"
        SystemDecorations="None" Background="Transparent"
        TransparencyLevelHint="Transparent"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False">

    <Border x:Name="Root" CornerRadius="30" Margin="18" Opacity="0"
            Background="{DynamicResource Card}"
            BorderBrush="{DynamicResource Accent}" BorderThickness="1"
            BoxShadow="0 18 46 -14 #88000000">
        <StackPanel VerticalAlignment="Center">
            <Grid Width="150" Height="150" HorizontalAlignment="Center">
                <Ellipse x:Name="SpinRing" Width="146" Height="146" Stroke="{DynamicResource Accent}"
                         StrokeThickness="2" StrokeDashArray="4,5" Opacity="0.55"
                         RenderTransformOrigin="50%,50%" />
                <Border Width="118" Height="118" CornerRadius="59" Background="#332630"
                        BorderBrush="{DynamicResource Accent}" BorderThickness="2">
                    <Viewbox Width="56" Height="56">
                        <Canvas Width="24" Height="24">
                            <Path Stroke="{DynamicResource Accent}" StrokeThickness="3.2" StrokeLineCap="Round"
                                  StrokeJoin="Round" Data="M12,15 L12,21.5" />
                            <Path Stroke="{DynamicResource Accent}" StrokeThickness="1.7" StrokeLineCap="Round"
                                  StrokeJoin="Round"
                                  Data="M12,15 L12,3.5 M12,15 C11,9.5 9.8,6.5 9.3,3.7 M12,15 C13,9.5 14.2,6.5 14.7,3.7 M12,15 C10,10.5 7.6,8.5 6.6,5 M12,15 C14,10.5 16.4,8.5 17.4,5 M9.2,14.4 Q12,16.2 14.8,14.4" />
                        </Canvas>
                    </Viewbox>
                </Border>
            </Grid>

            <TextBlock Classes="display" FontSize="34" FontWeight="Black" HorizontalAlignment="Center"
                       Margin="0,22,0,0"><Run Text="MAT" Foreground="{DynamicResource Cream}" /><Run Text="CHA" Foreground="{DynamicResource Accent}" /></TextBlock>
            <TextBlock Classes="display" Text="stay green" FontSize="16" FontStyle="Italic"
                       Foreground="{DynamicResource Accent}" HorizontalAlignment="Center" Margin="0,4,0,0" />

            <Border Width="180" Height="4" CornerRadius="2" Background="#22FFFFFF" Margin="0,30,0,0">
                <Border x:Name="ProgressFill" Height="4" CornerRadius="2" Width="0"
                        Background="{DynamicResource Accent}" HorizontalAlignment="Left" />
            </Border>
        </StackPanel>
    </Border>
</Window>
